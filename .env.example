# ──────────────────────────────────────────────
#  I CAN School · Safeguarding Platform
#  Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# ── Admin master code ────────────────────────
# The Lead DSL logs in with this code the first time to access
# the User Management panel and create accounts for all staff.
# Choose something strong — treat it like a password.
ADMIN_CODE=Christof97740590!

# SMTP — Gmail example (requires a Gmail App Password)
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate a password for "Mail" on "Windows Computer"
# 4. Paste the 16-character password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-school-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Office 365 / Outlook example:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourname@school.org
# SMTP_PASS=YourPassword

# Server port (default: 3000)
PORT=3000

# Allow frontend origin to call API when hosted separately
# Example: https://yourname.github.io
FRONTEND_ORIGIN=*
