# ── Admin master code ────────────────────────
# The Lead DSL logs in with this code the first time to access
# the User Management panel and create accounts for all staff.
# Change this to your preferred admin code (treat it like a password)
ADMIN_CODE=Christof97740590!

# Server port (default: 3000)
PORT=3000

# Allow frontend origin to call API when hosted separately
# Example: https://yourname.github.io
FRONTEND_ORIGIN=*

# Optional: Email configuration for sending reports
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-school-email@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx
